# --- THÔNG SỐ KẾT NỐI (ĐIỀN VÀO NẾU TEST LOCAL HOẶC VPS) ---
# Lưu ý: Nếu đưa lên Render.com, hãy điền các biến này vào mục Environment Variables trên web Render

# 1. Cơ sở dữ liệu (Supabase)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=eyJxxxxxxxxxxxxxxxxxxxx

# 2. Kho lưu ảnh (Cloudinary)
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# 3. Cổng thanh toán (PayOS)
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=

# 4. Mật khẩu trang Admin
ADMIN_TOKEN=admin:harmony
